# Cap · DevRoom — copy to dashboard/.env.local and fill in values
# cp dashboard/.env.example dashboard/.env.local

# Required for agent runs (Cursor Integrations → API keys)
CURSOR_API_KEY=

# Optional — required when accessing dashboard from iPhone/LAN (mobile app)
DEVROOM_API_TOKEN=

# SQLite database (relative to dashboard/)
DATABASE_URL=file:../data/devroom.db

# Repo root (defaults to parent of dashboard/)
# DEVROOM_ROOT=/Users/you/Desktop/Projects/Cap-DevRoom

# Where agent sandboxes are rsynced from live Cap app repos
# DEVROOM_SANDBOX_ROOT=/Users/you/Desktop/Projects/Cap-DevRoom/sandboxes

# Source portfolio apps on disk (for sync:sandboxes)
# DEVROOM_PROJECTS_ROOT=/Users/you/Desktop/Projects

# Optional — WhatsApp webhook for high-risk approval alerts
# WHATSAPP_WEBHOOK_URL=
