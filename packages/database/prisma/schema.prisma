generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Approval {
  id          String   @id @default(cuid())
  title       String
  description String
  agent       String
  projectId   String   @default("VaultCap")
  risk        String
  status      String   @default("pending")
  task        String?
  source      String   @default("demo")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([agent])
}

model AgentJob {
  id         String   @id @default(cuid())
  codename   String
  task       String
  projectId  String
  risk       String
  status     String   @default("PENDING")
  output     String?
  error      String?
  tokensUsed Int      @default(0)
  costUsd    Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@index([codename])
  @@index([createdAt])
}

model Task {
  id          String    @id @default(cuid())
  description String
  agent       String
  priority    String    @default("NORMAL")
  risk        String    @default("Low")
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([status])
}

model Priority {
  id        String   @id @default(cuid())
  text      String
  done      Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Briefing {
  id        String   @id @default(cuid())
  dateKey   String   @unique
  content   String
  source    String   @default("rules")
  createdAt DateTime @default(now())

  @@index([dateKey])
}

model ActivityLog {
  id        String   @id @default(cuid())
  agent     String
  action    String
  type      String   @default("info")
  projectId String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AgentMemory {
  id        String   @id @default(cuid())
  codename  String   @unique
  bullets   String   @default("[]")
  updatedAt DateTime @updatedAt
}

model Handoff {
  id        String   @id @default(cuid())
  source    String   @default("markroom")
  codename  String
  task      String
  projectId String   @default("VaultCap")
  risk      String   @default("Medium")
  status    String   @default("pending")
  metadata  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([codename])
}
