generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Approval {
  id          String   @id @default(cuid())
  title       String
  description String
  agent       String
  projectId   String   @default("VaultCap")
  risk        String
  status      String   @default("pending")
  task        String?
  source      String   @default("demo")
  decidedBy   String?
  decidedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([agent])
}

model AgentJob {
  id         String   @id @default(cuid())
  codename   String
  task       String
  projectId  String
  risk       String
  status     String   @default("PENDING")
  output     String?
  error      String?
  testResult String?
  tokensUsed Int      @default(0)
  costUsd    Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@index([codename])
  @@index([createdAt])
}

model Task {
  id          String    @id @default(cuid())
  description String
  agent       String
  priority    String    @default("NORMAL")
  risk        String    @default("Low")
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([status])
}

model Priority {
  id        String   @id @default(cuid())
  text      String
  done      Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Briefing {
  id        String   @id @default(cuid())
  dateKey   String   @unique
  content   String
  source    String   @default("rules")
  createdAt DateTime @default(now())

  @@index([dateKey])
}

model ActivityLog {
  id        String   @id @default(cuid())
  agent     String
  action    String
  type      String   @default("info")
  projectId String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AgentMemory {
  id        String   @id @default(cuid())
  codename  String   @unique
  bullets   String   @default("[]")
  updatedAt DateTime @updatedAt
}

model Handoff {
  id        String   @id @default(cuid())
  source    String   @default("markroom")
  codename  String
  task      String
  projectId String   @default("VaultCap")
  risk      String   @default("Medium")
  status    String   @default("pending")
  issueId   String?
  metadata  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([codename])
}

model HealthCheck {
  id        String   @id @default(cuid())
  projectId String
  status    String
  latencyMs Int?
  detail    String?
  checkedAt DateTime @default(now())

  @@index([projectId])
  @@index([checkedAt])
}

/// Real portfolio projects — replaces hardcoded DEFAULT_PROJECTS.
model Project {
  id          String   @id
  name        String
  description String   @default("")
  status      String   @default("active") // active|paused|archived
  stack       String?
  liveUrl     String?
  repoUrl     String?
  openBugs    Int      @default(0)
  health      Int      @default(100) // 0-100 score
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  issues      Issue[]
}

/// Linear/Jira-style issue tracker — the workflow spine.
model Issue {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. VAULT-12
  title     String
  body      String   @default("")
  status    String   @default("backlog") // backlog|todo|in_progress|in_review|done|canceled
  priority  String   @default("medium") // urgent|high|medium|low|none
  type      String   @default("task") // bug|feature|task|chore
  agent     String? // assigned codename
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  labels    String   @default("[]")
  jobId     String? // linked agent run
  prUrl     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([projectId])
  @@index([agent])
}

/// Immutable audit trail for sensitive actions (approvals, spend).
model AuditLog {
  id        String   @id @default(cuid())
  actor     String   @default("founder")
  action    String // approval.approved, approval.rejected, budget.cap_hit...
  target    String?
  detail    String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action])
}

/// Durable per-sandbox lock — survives restarts, works across instances.
model SandboxLock {
  projectId String   @id
  jobId     String
  holder    String   @default("agent")
  expiresAt DateTime
  createdAt DateTime @default(now())
}

/// Recurring agent runs (cron-style autonomous crews).
model ScheduledRun {
  id            String    @id @default(cuid())
  name          String
  codename      String
  task          String
  projectId     String    @default("VaultCap")
  cadence       String    @default("daily") // hourly|daily|weekly
  mode          String    @default("local") // local|cloud
  portfolioLoop Boolean   @default(false)
  enabled       Boolean   @default(true)
  lastRunAt     DateTime?
  nextRunAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([enabled])
}

/// Daily AI spend ledger — enforces hard budget caps.
model BudgetDay {
  dateKey   String   @id // YYYY-MM-DD
  tokens    Int      @default(0)
  costUsd   Float    @default(0)
  runs      Int      @default(0)
  updatedAt DateTime @updatedAt
}

/// Per-app launch-readiness checks — auto-scanned + founder-approved.
model ReadinessCheck {
  id         String   @id @default(cuid())
  projectId  String
  checkId    String // stable definition id, e.g. "appstore.icon1024"
  category   String // Product|Engineering|QA|Release|AppStore|Launch
  label      String
  status     String   @default("pending") // pass|warn|fail|pending|na
  detail     String?
  auto       Boolean  @default(true)
  approvedBy String?
  approvedAt DateTime?
  updatedAt  DateTime @updatedAt

  @@unique([projectId, checkId])
  @@index([projectId])
}
